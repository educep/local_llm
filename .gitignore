# bench artifacts (JSON results are small enough to commit; exclude transient noise)
bench/results/*.tmp
bench/results/*.log

# editor / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# secrets
.env
.env.*
!.env.example

# AI assistant artifacts (kept local, not versioned)
CLAUDE.md
.claude/
.cursor/
.cursorrules
.aider*
.github/copilot-*
plans/
learning/
